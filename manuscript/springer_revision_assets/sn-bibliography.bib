@inproceedings{chu_chatasd_2024,
	address = {Shenzhen China},
	title = {{ChatASD}: {A} {Dialogue} {Framework} for {LLMs} {Enhanced} by {Autism} {Knowledge} {Graph} {Retrieval}},
